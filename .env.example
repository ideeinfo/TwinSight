# ========================================
# TwinSight 统一环境变量模板 (.env.example)
# 部署或本地开发前，请复制此文件为 .env 并填入实际值
# ========================================

# ======== 通用环境 ========
NODE_ENV=production
SERVER_PORT=3001

# ======== 前端依赖 (必须以 VITE_ 开头) ========
# API 请求的 Base URL
VITE_API_URL=http://localhost:3001

# ======== 后端依赖 : 数据库 ========
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=twinsight
DB_USER=postgres
DB_PASSWORD=YOUR_DB_PASSWORD

# ======== 后端依赖 : InfluxDB ========
INFLUX_URL=http://127.0.0.1:8086
INFLUX_ORG=demo
INFLUX_BUCKET=twinsight
INFLUX_TOKEN=YOUR_INFLUX_TOKEN

# ======== 后端依赖 : 微服务 ========
LOGIC_ENGINE_URL=http://127.0.0.1:8000

# ======== 后端依赖 : AI ========
OPENWEBUI_URL=http://127.0.0.1:8080
OPENWEBUI_API_KEY=YOUR_API_KEY
